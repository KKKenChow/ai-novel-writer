# 复制此文件为 .env 并填入你的配置
# 本工具兼容所有 OpenAI 标准格式的 API 接口

# API Key（各平台在控制台获取）
# - 火山引擎方舟: 使用通用按量付费的 Key（不要用 CodingPlan 优惠订阅的 Key 做非编程用途，会违规）
# - DeepSeek: https://platform.deepseek.com
# - OpenAI / 兼容中转: 对应平台的 Key
VOLC_API_KEY=your_api_key_here

# API Base URL（填入你所用平台的 OpenAI 兼容接口地址）
# - 火山引擎方舟: https://ark.cn-beijing.volces.com/api/v3/chat/completions
# - DeepSeek:      https://api.deepseek.com/v1/chat/completions
# - OpenAI:        https://api.openai.com/v1/chat/completions
# - 其他兼容平台:   参考其文档填写 chat/completions 端点
VOLC_API_BASE=https://ark.cn-beijing.volces.com/api/v3/chat/completions

# 模型名称（填入你所用平台支持的模型 ID）
# - 火山引擎方舟: doubao-pro-4k / doubao-pro-32k 等
# - DeepSeek:      deepseek-chat / deepseek-reasoner 等
# - OpenAI:        gpt-4o / gpt-4o-mini 等
VOLC_MODEL=doubao-pro-32k
